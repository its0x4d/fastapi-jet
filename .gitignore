# Ignore Python cache files
__pycache__/
*.py[cod]
*$py.class

# Test and lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

# Ignore IDE-specific files and directories
.idea/
.vscode/
*.swp
*.swo

# Ignore virtual environment directories
.venv/
.venv*/
venv/
env/
ENV/

# Ignore logs and other build artifacts
logs/
*.log
*.bak
*.tmp

# Ignore database files
*.db
*.sqlite

# Ignore compiled binaries
*.dll
*.so
*.dylib

# Packaging
build/
dist/
*.egg-info/

# Archives
*.zip
*.rar
*.gz
*.tar.gz

# Cursor local state (rules in .cursor/rules/ are tracked)
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Local-only planning (not published)
DEVELOPMENT_PLAN.md

# Local generated test projects
myapi/

# MkDocs build output
site/

# Sandbox / temp pytest dirs
pytest-cache-files-*/
